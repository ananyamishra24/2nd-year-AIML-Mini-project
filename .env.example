# Azure AI Foundry — Anthropic Claude Sonnet 4.6 (story text generation, required)
# Endpoint is the BASE URL of the Anthropic-compatible deployment, WITHOUT /v1/messages.
# The Anthropic SDK appends /v1/messages itself.
CLAUDE_API_KEY=your_azure_ai_foundry_api_key_here
CLAUDE_ENDPOINT=https://<your-resource>.services.ai.azure.com/anthropic
CLAUDE_MODEL=claude-sonnet-4-6

# Azure OpenAI GPT-4o — Moonface face scanning
GPT4O_VISION_API_KEY=your_azure_api_key_here
GPT4O_VISION_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview

# Azure OpenAI gpt-4o-mini-tts — expressive TTS with `instructions` steering
# The endpoint must be the full deployment URL, including api-version.
AZURE_TTS_API_KEY=your_azure_openai_key_here
AZURE_TTS_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/openai/deployments/gpt-4o-mini-tts/audio/speech?api-version=2025-03-01-preview

# Azure AI Translator (multilingual story delivery)
# Key is the subscription key of the Translator / multi-service resource.
# Region is required for multi-service resources (e.g. "eastus2"); leave blank
# for single-service Translator resources provisioned as "global".
AZURE_TRANSLATOR_KEY=your_azure_translator_key_here
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/
AZURE_TRANSLATOR_REGION=eastus2

# Azure OpenAI gpt-image-1.5 (required for image generation)
# Get these from your Azure AI Foundry / Cognitive Services resource
AZURE_GPT_IMAGE_API_KEY=your_azure_gpt_image_api_key_here
AZURE_GPT_IMAGE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/openai/deployments/gpt-image-1.5/images/generations?api-version=2024-02-01

# Auth
JWT_SECRET_KEY=your_random_secret_key_here
TOKEN_EXPIRY_HOURS=72

# Google OAuth (optional — enables "Continue with Google" on the login page)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised JavaScript origins: http://localhost:5002
# Authorised redirect URIs: not required (token-based flow)
GOOGLE_CLIENT_ID=

# Database (leave empty for SQLite fallback)
DATABASE_URL=

# Cloud Storage (optional — leave empty for local storage)
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=story-images
