GEMINI_API_KEY=your_gemini_api_key_here

# Flux 2 Pro (Black Forest Labs via Azure AI Foundry)
FLUX2PRO_API_KEY=your_flux2pro_api_key_here
FLUX2PRO_ENDPOINT=https://your-endpoint.services.ai.azure.com/providers/blackforestlabs/v1/flux-2-pro?api-version=preview

# Auth
JWT_SECRET_KEY=your_random_secret_key_here
TOKEN_EXPIRY_HOURS=72

# Database (leave empty for SQLite fallback)
DATABASE_URL=

# Cloud Storage (optional — leave empty for local storage)
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=story-images
